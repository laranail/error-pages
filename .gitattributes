# Normalize line endings
* text=auto eol=lf

# Keep the prebuilt browser bundle checked out with LF (it ships in the package)
public/assets/** text eol=lf

# Exclude dev/test cruft and asset sources from the distributed package
/.github            export-ignore
/tests              export-ignore
/docs               export-ignore
/resources/assets   export-ignore
/node_modules       export-ignore
.editorconfig       export-ignore
.gitattributes      export-ignore
.gitignore          export-ignore
phpunit.xml.dist    export-ignore
phpstan.neon        export-ignore
pint.json           export-ignore
rector.php          export-ignore
package.json        export-ignore
vite.config.js      export-ignore
