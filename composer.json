{
    "name": "laranail/server-error-pages",
    "description": "Branded, self-contained error pages for Laravel that survive total app failure: dynamic Blade views, static HTML for when PHP is down (502/503/504), and generated Apache/Nginx config, all from one component source.",
    "keywords": [
        "laravel",
        "error-pages",
        "http-errors",
        "maintenance",
        "static-html",
        "nginx",
        "apache",
        "shared-hosting",
        "vps",
        "laranail"
    ],
    "homepage": "https://opensource.simtabi.com/products/laranail/server-error-pages",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi LLC",
            "email": "opensource@simtabi.com",
            "homepage": "https://opensource.simtabi.com",
            "role": "Organization"
        },
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/laranail/server-error-pages/issues",
        "source": "https://github.com/laranail/server-error-pages",
        "docs": "https://opensource.simtabi.com/documentation/laranail/server-error-pages/"
    },
    "require": {
        "php": "^8.4.1 || ^8.5",
        "illuminate/console": "^13.0",
        "illuminate/contracts": "^13.0",
        "illuminate/filesystem": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/translation": "^13.0",
        "illuminate/view": "^13.0",
        "laranail/console": "^1.1",
        "laranail/enumerator": "^0.4",
        "laranail/package-tools": "^4.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\ServerErrorPages\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\ServerErrorPages\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage",
        "pint": "vendor/bin/pint --test",
        "pint-fix": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "rector": "vendor/bin/rector process --dry-run",
        "rector-fix": "vendor/bin/rector process",
        "lint": [
            "@pint",
            "@phpstan",
            "@rector"
        ],
        "audit": "composer audit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\ServerErrorPages\\Providers\\ServerErrorPagesServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
