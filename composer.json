{
    "name": "laranail/error-pages",
    "description": "Beautiful, branded production error and exception pages for Laravel that complement Ignition \u2014 Blade, API/JSON, Inertia, Filament and Nova, progressively enhanced and fully configurable.",
    "keywords": [
        "laravel",
        "error-pages",
        "exception-handler",
        "http-errors",
        "inertia",
        "filament",
        "nova",
        "ignition",
        "laranail"
    ],
    "homepage": "https://opensource.simtabi.com/products/laranail/error-pages",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi LLC",
            "email": "opensource@simtabi.com",
            "homepage": "https://opensource.simtabi.com",
            "role": "Organization"
        },
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/laranail/error-pages/issues",
        "source": "https://github.com/laranail/error-pages",
        "docs": "https://opensource.simtabi.com/documentation/laranail/error-pages/"
    },
    "require": {
        "php": "^8.4.1 || ^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/translation": "^13.0",
        "illuminate/view": "^13.0",
        "laranail/console": "^0.1",
        "laranail/enumerator": "^0.1",
        "laranail/package-tools": "^0.1"
    },
    "require-dev": {
        "inertiajs/inertia-laravel": "^3.1",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "livewire/livewire": "^4.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\ErrorPages\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\ErrorPages\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage",
        "pint": "vendor/bin/pint --test",
        "pint-fix": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "rector": "vendor/bin/rector process --dry-run",
        "rector-fix": "vendor/bin/rector process",
        "lint": [
            "@pint",
            "@phpstan",
            "@rector"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\ErrorPages\\Providers\\ErrorPagesServiceProvider"
            ],
            "aliases": {
                "ErrorPages": "Simtabi\\Laranail\\ErrorPages\\Facades\\ErrorPages"
            }
        },
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/laranail/console"
        },
        {
            "type": "vcs",
            "url": "https://github.com/laranail/enumerator"
        },
        {
            "type": "vcs",
            "url": "https://github.com/laranail/package-tools"
        }
    ],
    "suggest": {
        "inertiajs/inertia-laravel": "Enables the inertia stack (Inertia + Vue/React error pages).",
        "livewire/livewire": "Enables the livewire stack (a full-page Livewire 4 ErrorPage component)."
    }
}
