{
    "name": "laranail/laravel-error-pages",
    "description": "Beautiful, branded production error and exception pages for Laravel that complement Ignition — Blade, API/JSON, Inertia, Filament and Nova, all Alpine-enhanced and fully configurable.",
    "keywords": [
        "laravel",
        "error-pages",
        "exception-handler",
        "http-errors",
        "inertia",
        "filament",
        "nova",
        "ignition",
        "laranail"
    ],
    "homepage": "https://opensource.simtabi.com/products/laranail/laravel-error-pages",
    "license": "MIT",
    "authors": [
        {
            "name": "Simtabi LLC",
            "email": "opensource@simtabi.com",
            "homepage": "https://opensource.simtabi.com",
            "role": "Organization"
        },
        {
            "name": "Imani Manyara",
            "email": "imani@simtabi.com",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/laranail/laravel-error-pages/issues",
        "source": "https://github.com/laranail/laravel-error-pages",
        "docs": "https://opensource.simtabi.com/documentation/laranail/laravel-error-pages/"
    },
    "require": {
        "php": "^8.4.1 || ^8.5",
        "illuminate/contracts": "^13.0",
        "illuminate/http": "^13.0",
        "illuminate/support": "^13.0",
        "illuminate/translation": "^13.0",
        "illuminate/view": "^13.0",
        "laranail/console": "^0.1",
        "laranail/error-pages": "*",
        "laranail/package-tools": "^0.1"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/phpstan": "^2.0",
        "rector/rector": "^2.0",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "Simtabi\\Laranail\\LaravelErrorPages\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Simtabi\\Laranail\\LaravelErrorPages\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --no-coverage",
        "test-coverage": "vendor/bin/pest --coverage",
        "pint": "vendor/bin/pint --test",
        "pint-fix": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --no-progress",
        "rector": "vendor/bin/rector process --dry-run",
        "rector-fix": "vendor/bin/rector process",
        "lint": [
            "@pint",
            "@phpstan",
            "@rector"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Simtabi\\Laranail\\LaravelErrorPages\\Providers\\ErrorPagesServiceProvider"
            ],
            "aliases": {
                "ErrorPages": "Simtabi\\Laranail\\LaravelErrorPages\\Facades\\ErrorPages"
            }
        },
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../error-pages",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../tools/console",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "../package/tools",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/laranail/console"
        },
        {
            "type": "vcs",
            "url": "https://github.com/laranail/package-tools"
        }
    ]
}
